/target
Cargo.lock.bak
.DS_Store
*.swp
*.tmp
.claude/
.rivet/

# Blog post HTML mirrors — fetched ad-hoc by research agents; not source.
docs/research/blog-mirror/

# Verdict-suite build outputs — regenerated on every CI run by build-all.sh.
verdicts/*/target/
verdicts/*/Cargo.lock
verdicts/*/*.wasm

# witness-component is a standalone workspace (see parent Cargo.toml).
# Its target/ is a build artefact; Cargo.lock IS committed — it ships a
# release wasm artifact, so its dep set must be pinned/reproducible.
crates/witness-component/target/

# witness-viz is also a standalone workspace (v0.9.0+). Same reasoning —
# Cargo.lock committed because it builds a released binary.
crates/witness-viz/target/

# Playwright outputs.
tests/playwright/node_modules/
tests/playwright/test-results/
tests/playwright/playwright-report/
tests/playwright/.last-run.json

# Local smoke-test output from tools/run_verification.py.
verification-results.json

*.wasm.map
